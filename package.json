{
  "name": "local-event-script",
  "version": "0.1.0",
  "description": "Browser-local event choreography runtime. A Datastar plugin + standalone custom element.",
  "type": "module",
  "main": "dist/local-event-script.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.dev.mjs",
    "typecheck": "tsc --noEmit",
    "dev:server": "cd server && node --watch --experimental-strip-types --env-file=.env src/index.ts",
    "dev:bundle": "node esbuild.dev.mjs",
    "dev": "concurrently \"npm run dev:bundle\" \"npm run dev:server\""
  },
  "peerDependencies": {
    "datastar": "*"
  },
  "peerDependenciesOptional": {
    "datastar": true
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
