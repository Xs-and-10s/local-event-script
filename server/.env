# ─────────────────────────────────────────────────────────────────────────────
# local-event-script dev server — environment variables
#
# Copy this file to .env and fill in your keys.
# The server degrades gracefully if keys are missing:
#   - FIRMS_MAP_KEY missing → /api/d3/fires returns { fires: [], warning: "..." }
#   - OPENSKY_* missing    → /api/d3/flights returns { flights: [], warning: "..." }
# ─────────────────────────────────────────────────────────────────────────────

# NASA FIRMS (Fire Information for Resource Management System)
# Required for the wildfire layer in the /d3 "Living Map" demo.
# Get a free key (takes ~2 minutes, no credit card):
#   https://firms.modaps.eosdis.nasa.gov/api/
# After registering, your MAP_KEY appears on the API page.
FIRMS_MAP_KEY=

# OpenSky Network (optional — enables live flight trails in /d3 demo)
# Free account: https://opensky-network.org/index.php?option=com_users&view=registration
# After registering, create an API client at:
#   https://opensky-network.org/data/api  (My API clients → New client)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
